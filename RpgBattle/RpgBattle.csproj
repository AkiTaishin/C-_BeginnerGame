<Project Sdk="Microsoft.NET.Sdk" ToolsVersion="15.0">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <!-- Visual Studio 2026 付属の .NET 10 でそのままビルドできるよう net10.0 を使用 -->
