    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <RootNamespace>RpgBattle</RootNamespace>
    <AssemblyName>RpgBattle</AssemblyName>
  </PropertyGroup>
</Project>